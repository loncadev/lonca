# Reject install on a Node version that does not satisfy `engines`.
engine-strict=true

# Be explicit about lockfile expectations.
prefer-frozen-lockfile=true

# Surface peer dependency mismatches instead of silently ignoring them.
strict-peer-dependencies=true

# pnpm 10 auto-installs peers by default; declare it explicitly.
auto-install-peers=true

# Symlink workspace packages between each other (default).
link-workspace-packages=true

# Keep package install scripts enabled (paired with onlyBuiltDependencies allowlist
# in pnpm-workspace.yaml for supply-chain safety).
ignore-scripts=false
