{
  "name": "@lonca/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Lonca — open-source SDKs and tooling for Turkish e-commerce marketplaces",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loncadev/lonca.git"
  },
  "homepage": "https://github.com/loncadev/lonca",
  "bugs": {
    "url": "https://github.com/loncadev/lonca/issues"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:root": "eslint .",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.15.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.15.0"
  }
}
