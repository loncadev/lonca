{
  "name": "@lonca/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Lonca — open-source SDKs and tooling for Turkish e-commerce marketplaces",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loncadev/lonca.git"
  },
  "homepage": "https://github.com/loncadev/lonca",
  "bugs": {
    "url": "https://github.com/loncadev/lonca/issues"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:root": "eslint .",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean",
    "docs:dev": "pnpm --filter @lonca/docs dev",
    "docs:build": "pnpm --filter @lonca/docs build",
    "docs:preview": "pnpm --filter @lonca/docs preview",
    "docs:sync-brand": "pnpm --filter @lonca/docs sync-brand",
    "try:trendyol": "tsx --env-file=.env examples/try-trendyol.mts",
    "try:hepsiburada": "tsx --env-file=.env examples/try-hepsiburada.mts",
    "try:inspect-hb-categories": "tsx --env-file=.env examples/inspect-hb-categories.mts",
    "try:inspect-hb-orders": "tsx --env-file=.env examples/inspect-hb-orders.mts",
    "try:inspect-hb-catalog": "tsx --env-file=.env examples/inspect-hb-catalog.mts",
    "try:inspect-orders": "tsx --env-file=.env examples/inspect-orders.mts",
    "try:inspect-attribute-values": "tsx --env-file=.env examples/inspect-attribute-values.mts",
    "try:inspect-product-reads": "tsx --env-file=.env examples/inspect-product-reads.mts",
    "try:inspect-inventory-and-price": "tsx --env-file=.env examples/inspect-inventory-and-price.mts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1",
      "vite": "^8.0.16"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^10.0.1",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
