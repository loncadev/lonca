{
  "name": "@lonca/core",
  "version": "0.6.0",
  "description": "Shared primitives for Lonca marketplace SDKs: money, errors, retry, logger, rate limiter.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loncadev/lonca.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/loncadev/lonca/tree/main/packages/core#readme",
  "bugs": "https://github.com/loncadev/lonca/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('.turbo',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
