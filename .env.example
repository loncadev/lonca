# Copy to `.env` and fill in real values. `.env` is gitignored.
# Used by the read-only smoke scripts: `pnpm try:trendyol`, `pnpm try:hepsiburada`,
# and the `pnpm try:inspect-*` inspectors under examples/.

# ─── Trendyol (@lonca/trendyol) ──────────────────────────────────────────────
# Partner Panel → Account Info → Integration Information (master-user only).
# Required
TY_SELLER_ID=12345
TY_API_KEY=your_api_key_here
TY_API_SECRET=your_api_secret_here

# Optional
TY_ENV=prod                   # 'prod' (no IP whitelist) or 'stage' (needs IP whitelist)
TY_INTEGRATOR_NAME=SelfIntegration  # 'SelfIntegration' if the seller owns the integration; else the integrator company name
# TY_SKIP_SUPPLIERS=1         # uncomment to skip the suppliers call (Trendyol caps it at 1 req/hour)

# ─── Hepsiburada (@lonca/hepsiburada) ────────────────────────────────────────
# Merchant Portal → Settings → Integrations.
# Required
HB_MERCHANT_ID=00000000-0000-0000-0000-000000000000   # UUID-shaped merchant id
HB_API_USER=your_basic_auth_username
HB_API_PASS=your_basic_auth_password

# Optional
HB_ENV=sit                    # 'sit' (sandbox, default) or 'prod'
HB_INTEGRATOR_NAME=MyCompany  # bare integrator name sent as User-Agent — must be the name
                              # registered in the Merchant Portal, or prod rejects with 401/403
