# Copy to `.env` and fill in real values. .env is gitignored.
# Used by the `pnpm try:trendyol` smoke-test script.

# Required
TY_SELLER_ID=12345
TY_API_KEY=your_api_key_here
TY_API_SECRET=your_api_secret_here

# Optional
TY_ENV=prod                   # 'prod' (no IP whitelist) or 'stage' (needs IP whitelist)
TY_INTEGRATOR_NAME=LoncaSmokeTest
# TY_SKIP_SUPPLIERS=1         # uncomment to skip suppliers call (1 req/hour limit)
